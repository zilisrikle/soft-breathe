---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  activePage: string;
  fullHeight?: boolean;
}

const { title, activePage, fullHeight = false } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  
  <!-- SEO & Meta Tags -->
  <title>{title === 'Soft Breathe' ? title : `${title} | Soft Breathe`}</title>
  <meta name="description" content="Ancient breathing science meets modern neuroscience. Free breathing practices for focus, sleep, and calm. No signup required.">
  <link rel="canonical" href={`https://softbreathe.com${activePage === 'eastern' ? '' : '/' + activePage}`}>
  
  <!-- Open Graph -->
  <meta property="og:title" content="Soft Breathe — The Ancient Science of Breath">
  <meta property="og:description" content="4-7-8, Box Breathing, and more. Open and practice immediately.">
  <meta property="og:image" content="https://softbreathe.com/og-image.jpg">
  <meta property="og:url" content={`https://softbreathe.com${activePage === 'eastern' ? '' : '/' + activePage}`}>
  <meta property="og:type" content="website">

  <!-- JSON-LD -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Soft Breathe",
    "description": "Ancient breathing practices backed by modern neuroscience. Free, no signup required.",
    "url": "https://softbreathe.com",
    "applicationCategory": "HealthApplication",
    "offers": {"@type": "Offer", "price": "0"}
  }
  </script>

  <!-- Icons & Fonts -->
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link href="https://fonts.googleapis.com/css2?family=IM+Fell+English:ital@0;1&family=Noto+Serif:ital,wght@0,300;0,400;1,300&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet" />

  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-5NYSSQF07Z"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-5NYSSQF07Z');
  </script>
</head>
<body class:list={[{ 'full-height': fullHeight }]}>

<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>

<Nav activePage={activePage} />

<slot />

<Footer />

<script>
  // Custom cursor
  const cursor = document.getElementById('cursor')!;
  const ring = document.getElementById('cursorRing')!;
  let mx = 0, my = 0, rx = 0, ry = 0;

  document.addEventListener('mousemove', (e) => {
    mx = e.clientX; my = e.clientY;
    cursor.style.left = mx + 'px';
    cursor.style.top = my + 'px';
  });

  (function animateRing() {
    rx += (mx - rx) * 0.12;
    ry += (my - ry) * 0.12;
    ring.style.left = rx + 'px';
    ring.style.top = ry + 'px';
    requestAnimationFrame(animateRing);
  })();

  document.querySelectorAll('a, button, .pattern-item, .cycle-btn').forEach((el) => {
    el.addEventListener('mouseenter', () => {
      cursor.style.transform = 'translate(-50%,-50%) scale(2.5)';
      ring.style.width = '48px';
      ring.style.height = '48px';
    });
    el.addEventListener('mouseleave', () => {
      cursor.style.transform = 'translate(-50%,-50%) scale(1)';
      ring.style.width = '32px';
      ring.style.height = '32px';
    });
  });

  // Scroll fade-in observer
  const observer = new IntersectionObserver(
    (entries) => entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.12 }
  );
  document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));
</script>

<style>
  body.full-height { height: 100%; overflow: hidden; }
  body.full-height html { height: 100%; }
</style>

</body>
</html>
